        -- ───────────────── DROPDOWN ─────────────────
        function Tab:AddDropdown(dropdownOptions)
            dropdownOptions = dropdownOptions or {}
            local text = dropdownOptions.Text or "Dropdown"
            local description = dropdownOptions.Description or nil
            local items = dropdownOptions.Items or {}
            local default = dropdownOptions.Default or nil
            local multiSelect = dropdownOptions.MultiSelect or false
            local callback = dropdownOptions.Callback or function() end
            local icon = dropdownOptions.Icon or nil
            local flag = dropdownOptions.Flag or nil
            local theme = Utility.GetTheme()
            local parent = getParent(self)
            
            local headerHeight = description and 52 or 38
            local isOpen = false
            local selected = multiSelect and {} or default
            
            if multiSelect and default then
                if type(default) == "table" then
                    for _, v in ipairs(default) do
                        selected[v] = true
                    end
                end
            end
            
            local dropdownFrame = Utility.Create("Frame", {
                Name = "Dropdown_" .. text,
                Size = UDim2.new(1, 0, 0, headerHeight),
                BackgroundColor3 = theme.CardBackground,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                ZIndex = 5,
                Parent = parent,
            })
            RegisterThemeObject(dropdownFrame, "BackgroundColor3", "CardBackground")
            Utility.AddCorner(dropdownFrame, 8)
            
            local leftOffset = 14
            if icon then
                Utility.Create("TextLabel", {
                    Position = UDim2.new(0, 14, 0, description and 8 or 0),
                    Size = UDim2.new(0, 22, 0, description and 22 or headerHeight),
                    BackgroundTransparency = 1,
                    Text = icon,
                    TextSize = 16,
                    ZIndex = 7,
                    Parent = dropdownFrame,
                })
                leftOffset = 42
            end
            
            local dropdownLabel = Utility.Create("TextLabel", {
                Position = UDim2.new(0, leftOffset, 0, description and 8 or 0),
                Size = UDim2.new(1, -(leftOffset + 80), 0, description and 20 or headerHeight),
                BackgroundTransparency = 1,
                Text = text,
                TextColor3 = theme.Text,
                Font = Config.Font,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 7,
                Parent = dropdownFrame,
            })
            RegisterThemeObject(dropdownLabel, "TextColor3", "Text")
            
            if description then
                local descLabel = Utility.Create("TextLabel", {
                    Position = UDim2.new(0, leftOffset, 0, 28),
                    Size = UDim2.new(1, -(leftOffset + 80), 0, 18),
                    BackgroundTransparency = 1,
                    Text = description,
                    TextColor3 = theme.DimText,
                    Font = Config.Font,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    ZIndex = 7,
                    Parent = dropdownFrame,
                })
                RegisterThemeObject(descLabel, "TextColor3", "DimText")
            end
            
            -- Selected display
            local function getSelectedText()
                if multiSelect then
                    local selectedItems = {}
                    for item, v in pairs(selected) do
                        if v then table.insert(selectedItems, item) end
                    end
                    if #selectedItems == 0 then return "None" end
                    return table.concat(selectedItems, ", ")
                else
                    return selected or "None"
                end
            end
            
            local selectedLabel = Utility.Create("TextLabel", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -36, 0, description and 8 or 0),
                Size = UDim2.new(0, 60, 0, description and 20 or headerHeight),
                BackgroundTransparency = 1,
                Text = getSelectedText(),
                TextColor3 = theme.Accent,
                Font = Config.Font,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Right,
                TextTruncate = Enum.TextTruncate.AtEnd,
                ZIndex = 7,
                Parent = dropdownFrame,
            })
            RegisterThemeObject(selectedLabel, "TextColor3", "Accent")
            
            -- Arrow
            local arrow = Utility.Create("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -14, 0, headerHeight / 2),
                Size = UDim2.new(0, 16, 0, 16),
                BackgroundTransparency = 1,
                Text = "▼",
                TextColor3 = theme.DimText,
                Font = Config.Font,
                TextSize = 10,
                ZIndex = 7,
                Parent = dropdownFrame,
            })
            RegisterThemeObject(arrow, "TextColor3", "DimText")
            
            -- Items container
            local itemsContainer = Utility.Create("Frame", {
                Position = UDim2.new(0, 8, 0, headerHeight + 4),
                Size = UDim2.new(1, -16, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                ZIndex = 7,
                Parent = dropdownFrame,
            })
            Utility.AddLayout(itemsContainer, Enum.FillDirection.Vertical, 2)
            
            -- Create items
            local itemButtons = {}
            
            local function createItemButton(itemName)
                local isSelected = multiSelect and selected[itemName] or selected == itemName
                
                local itemBtn = Utility.Create("TextButton", {
                    Name = itemName,
                    Size = UDim2.new(1, 0, 0, 30),
                    BackgroundColor3 = isSelected and theme.Accent or theme.TertiaryBackground,
                    BackgroundTransparency = isSelected and 0.8 or 0,
                    Text = "",
                    BorderSizePixel = 0,
                    ZIndex = 8,
                    Parent = itemsContainer,
                })
                Utility.AddCorner(itemBtn, 6)
                
                local checkMark = Utility.Create("TextLabel", {
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(0, 20, 1, 0),
                    BackgroundTransparency = 1,
                    Text = isSelected and "✓" or "",
                    TextColor3 = theme.Accent,
                    Font = Config.TitleFont,
                    TextSize = 14,
                    ZIndex = 9,
                    Parent = itemBtn,
                })
                
                local itemLabel = Utility.Create("TextLabel", {
                    Position = UDim2.new(0, 32, 0, 0),
                    Size = UDim2.new(1, -42, 1, 0),
                    BackgroundTransparency = 1,
                    Text = itemName,
                    TextColor3 = isSelected and theme.Text or theme.SubText,
                    Font = Config.Font,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 9,
                    Parent = itemBtn,
                })
                
                itemBtn.MouseEnter:Connect(function()
                    Utility.Tween(itemBtn, {BackgroundColor3 = Utility.GetTheme().Accent, BackgroundTransparency = 0.7}, 0.15)
                end)
                itemBtn.MouseLeave:Connect(function()
                    local sel = multiSelect and selected[itemName] or selected == itemName
                    Utility.Tween(itemBtn, {
                        BackgroundColor3 = sel and Utility.GetTheme().Accent or Utility.GetTheme().TertiaryBackground,
                        BackgroundTransparency = sel and 0.8 or 0
                    }, 0.15)
                end)
                
                itemBtn.MouseButton1Click:Connect(function()
                    local t = Utility.GetTheme()
                    if multiSelect then
                        selected[itemName] = not selected[itemName]
                        local sel = selected[itemName]
                        checkMark.Text = sel and "✓" or ""
                        itemLabel.TextColor3 = sel and t.Text or t.SubText
                        Utility.Tween(itemBtn, {
                            BackgroundColor3 = sel and t.Accent or t.TertiaryBackground,
                            BackgroundTransparency = sel and 0.8 or 0,
                        }, 0.15)
                        selectedLabel.Text = getSelectedText()
                        pcall(callback, selected)
                    else
                        -- Deselect all
                        for _, data in pairs(itemButtons) do
                            data.Check.Text = ""
                            data.Label.TextColor3 = t.SubText
                            Utility.Tween(data.Button, {
                                BackgroundColor3 = t.TertiaryBackground,
                                BackgroundTransparency = 0
                            }, 0.15)
                        end
                        selected = itemName
                        checkMark.Text = "✓"
                        itemLabel.TextColor3 = t.Text
                        Utility.Tween(itemBtn, {
                            BackgroundColor3 = t.Accent,
                            BackgroundTransparency = 0.8,
                        }, 0.15)
                        selectedLabel.Text = getSelectedText()
                        pcall(callback, selected)
                    end
                end)
                
                itemButtons[itemName] = {
                    Button = itemBtn,
                    Check = checkMark,
                    Label = itemLabel,
                }
            end
            
            for _, item in ipairs(items) do
                createItemButton(item)
            end
            
            -- Toggle dropdown header button
            local headerBtn = Utility.Create("TextButton", {
                Size = UDim2.new(1, 0, 0, headerHeight),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 8,
                Parent = dropdownFrame,
            })
            
            local function toggleDropdown()
                isOpen = not isOpen
                local itemCount = 0
                for _ in pairs(itemButtons) do itemCount = itemCount + 1 end
                local expandedHeight = headerHeight + 8 + (itemCount * 32) + ((itemCount - 1) * 2) + 8
                
                Utility.Tween(dropdownFrame, {
                    Size = UDim2.new(1, 0, 0, isOpen and expandedHeight or headerHeight),
                }, 0.25, Enum.EasingStyle.Quart)
                
                Utility.Tween(arrow, {
                    Rotation = isOpen and 180 or 0,
                }, 0.25)
            end
            
            headerBtn.MouseButton1Click:Connect(toggleDropdown)
            
            headerBtn.MouseEnter:Connect(function()
                Utility.Tween(dropdownFrame, {BackgroundColor3 = Utility.GetTheme().TertiaryBackground}, 0.15)
            end)
            headerBtn.MouseLeave:Connect(function()
                Utility.Tween(dropdownFrame, {BackgroundColor3 = Utility.GetTheme().CardBackground}, 0.15)
            end)
            
            local DropdownObj = {}
            function DropdownObj:Set(value)
                if multiSelect then
                    selected = {}
                    if type(value) == "table" then
                        for _, v in ipairs(value) do selected[v] = true end
                    end
                else
                    selected = value
                end
                selectedLabel.Text = getSelectedText()
                -- Update visuals
                local t = Utility.GetTheme()
                for name, data in pairs(itemButtons) do
                    local sel = multiSelect and selected[name] or selected == name
                    data.Check.Text = sel and "✓" or ""
                    data.Label.TextColor3 = sel and t.Text or t.SubText
                    data.Button.BackgroundColor3 = sel and t.Accent or t.TertiaryBackground
                    data.Button.BackgroundTransparency = sel and 0.8 or 0
                end
                pcall(callback, selected)
            end
            function DropdownObj:Get()
                return selected
            end
            function DropdownObj:Refresh(newItems, keepSelected)
                -- Clear existing
                for _, data in pairs(itemButtons) do
                    data.Button:Destroy()
                end
                itemButtons = {}
                items = newItems
                if not keepSelected then
                    selected = multiSelect and {} or nil
                    selectedLabel.Text = getSelectedText()
                end
                for _, item in ipairs(newItems) do
                    createItemButton(item)
                end
                -- Resize if open
                if isOpen then
                    local itemCount = #newItems
                    local expandedHeight = headerHeight + 8 + (itemCount * 32) + (math.max(0, itemCount - 1) * 2) + 8
                    Utility.Tween(dropdownFrame, {Size = UDim2.new(1, 0, 0, expandedHeight)}, 0.25)
                end
            end
            function DropdownObj:Add(itemName)
                table.insert(items, itemName)
                createItemButton(itemName)
            end
            function DropdownObj:Remove(itemName)
                if itemButtons[itemName] then
                    itemButtons[itemName].Button:Destroy()
                    itemButtons[itemName] = nil
                    for i, v in ipairs(items) do
                        if v == itemName then
                            table.remove(items, i)
                            break
                        end
                    end
                end
            end
            
            if flag then
                Window.Elements[flag] = DropdownObj
            end
            
            return DropdownObj
        end
        
