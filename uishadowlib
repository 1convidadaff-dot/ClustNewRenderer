                ZIndex = 7,
                Parent = colorFrame,
            })
            Utility.AddCorner(colorPreview, 4)
            Utility.AddStroke(colorPreview, theme.Border, 1, 0.5)
            
            -- Header click
            local headerBtn = Utility.Create("TextButton", {
                Size = UDim2.new(1, 0, 0, 38),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 8,
                Parent = colorFrame,
            })
            
            -- HSV sliders
            local h, s, v = currentColor:ToHSV()
            
            local function createColorSlider(label, yPos, value, hue)
                local sliderBg = Utility.Create("Frame", {
                    Position = UDim2.new(0, 14, 0, yPos),
                    Size = UDim2.new(1, -28, 0, 22),
                    BackgroundTransparency = 1,
                    ZIndex = 7,
                    Parent = colorFrame,
                })
                
                local slLabel = Utility.Create("TextLabel", {
                    Size = UDim2.new(0, 14, 1, 0),
                    BackgroundTransparency = 1,
                    Text = label,
                    TextColor3 = theme.SubText,
                    Font = Config.TitleFont,
                    TextSize = 11,
                    ZIndex = 8,
                    Parent = sliderBg,
                })
                
                local track = Utility.Create("Frame", {
                    Position = UDim2.new(0, 20, 0.5, -4),
                    Size = UDim2.new(1, -50, 0, 8),
                    BackgroundColor3 = theme.SliderBackground,
                    BorderSizePixel = 0,
                    ZIndex = 8,
                    Parent = sliderBg,
                })
                Utility.AddCorner(track, 4)
                
                local fill = Utility.Create("Frame", {
                    Size = UDim2.new(value, 0, 1, 0),
                    BackgroundColor3 = theme.Accent,
                    BorderSizePixel = 0,
                    ZIndex = 9,
                    Parent = track,
                })
                Utility.AddCorner(fill, 4)
                
                local valLabel = Utility.Create("TextLabel", {
                    AnchorPoint = Vector2.new(1, 0),
                    Position = UDim2.new(1, 0, 0, 0),
                    Size = UDim2.new(0, 28, 1, 0),
                    BackgroundTransparency = 1,
                    Text = tostring(math.floor(value * 255)),
                    TextColor3 = theme.SubText,
                    Font = Config.Font,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    ZIndex = 8,
                    Parent = sliderBg,
                })
                
                local inputBtn = Utility.Create("TextButton", {
                    Size = UDim2.new(1, 0, 1, 6),
                    Position = UDim2.new(0, 0, 0, -3),
                    BackgroundTransparency = 1,
                    Text = "",
                    ZIndex = 10,
                    Parent = track,
                })
                
                return {
                    Track = track,
                    Fill = fill,
                    Input = inputBtn,
                    Label = valLabel,
                }
            end
            
            local hSlider = createColorSlider("H", 46, h, true)
            local sSlider = createColorSlider("S", 72, s, false)
            local vSlider = createColorSlider("V", 98, v, false)
            
            local function updateColor()
                currentColor = Color3.fromHSV(h, s, v)
                colorPreview.BackgroundColor3 = currentColor
                hSlider.Fill.Size = UDim2.new(h, 0, 1, 0)
                sSlider.Fill.Size = UDim2.new(s, 0, 1, 0)
                vSlider.Fill.Size = UDim2.new(v, 0, 1, 0)
                hSlider.Label.Text = tostring(math.floor(h * 360))
                sSlider.Label.Text = tostring(math.floor(s * 100))
                vSlider.Label.Text = tostring(math.floor(v * 100))
                
                -- Color the H slider fill with hue
                hSlider.Fill.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                sSlider.Fill.BackgroundColor3 = currentColor
                vSlider.Fill.BackgroundColor3 = currentColor
                
                pcall(callback, currentColor)
            end
            
            local function setupColorSlider(slider, updateFunc)
                local sliding = false
                slider.Input.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = true
                    end
                end)
                slider.Input.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = false
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        local rel = math.clamp((input.Position.X - slider.Track.AbsolutePosition.X) / slider.Track.AbsoluteSize.X, 0, 1)
                        updateFunc(rel)
                        updateColor()
                    end
                end)
                slider.Input.MouseButton1Click:Connect(function()
                    local rel = math.clamp((Mouse.X - slider.Track.AbsolutePosition.X) / slider.Track.AbsoluteSize.X, 0, 1)
                    updateFunc(rel)
                    updateColor()
                end)
            end
            
            setupColorSlider(hSlider, function(val) h = val end)
            setupColorSlider(sSlider, function(val) s = val end)
            setupColorSlider(vSlider, function(val) v = val end)
            
            updateColor()
            
            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Utility.Tween(colorFrame, {
                    Size = UDim2.new(1, 0, 0, isOpen and 130 or 38),
                }, 0.25)
            end)
            
            local ColorObj = {}
            function ColorObj:Set(color)
                h, s, v = color:ToHSV()
                updateColor()
            end
            function ColorObj:Get()
                return currentColor
            end
            
            if flag then Window.Elements[flag] = ColorObj end
            return ColorObj
        end
        
