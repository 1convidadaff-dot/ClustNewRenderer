    -- External button dragging
    local extDragging = false
    local extDragStart
    local extStartPos
    
    ExternalButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            extDragging = true
            extDragStart = input.Position
            extStartPos = ExternalButton.Position
            
            local moved = false
            local moveConn
            moveConn = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    extDragging = false
                    if moveConn then moveConn:Disconnect() end
                    if not moved then
                        Window:Toggle(true)
                    end
                end
            end)
            
            local dragConn
            dragConn = UserInputService.InputChanged:Connect(function(moveInput)
                if not extDragging then
                    dragConn:Disconnect()
                    return
                end
                if moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch then
                    local delta = moveInput.Position - extDragStart
                    if delta.Magnitude > 5 then
                        moved = true
                    end
                    ExternalButton.Position = UDim2.new(
                        extStartPos.X.Scale, extStartPos.X.Offset + delta.X,
                        extStartPos.Y.Scale, extStartPos.Y.Offset + delta.Y
                    )
                end
            end)
        end
    end)
    
