            })
            RegisterThemeObject(sliderLabel, "TextColor3", "Text")
            
            -- Value display
            local valueLabel = Utility.Create("TextLabel", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -14, 0, 8),
                Size = UDim2.new(0, 60, 0, 20),
                BackgroundTransparency = 1,
                Text = tostring(currentValue) .. suffix,
                TextColor3 = theme.Accent,
                Font = Config.TitleFont,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 7,
                Parent = sliderFrame,
            })
            RegisterThemeObject(valueLabel, "TextColor3", "Accent")
            
            local descOffset = 0
            if description then
                local descLabel = Utility.Create("TextLabel", {
                    Position = UDim2.new(0, leftOffset, 0, 26),
                    Size = UDim2.new(1, -(leftOffset + 14), 0, 16),
                    BackgroundTransparency = 1,
                    Text = description,
                    TextColor3 = theme.DimText,
                    Font = Config.Font,
                    TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    ZIndex = 7,
                    Parent = sliderFrame,
                })
                RegisterThemeObject(descLabel, "TextColor3", "DimText")
                descOffset = 14
            end
            
            -- Slider track
            local sliderTrack = Utility.Create("Frame", {
                Position = UDim2.new(0, 14, 0, 32 + descOffset),
                Size = UDim2.new(1, -28, 0, 8),
                BackgroundColor3 = theme.SliderBackground,
                BorderSizePixel = 0,
                ZIndex = 7,
                Parent = sliderFrame,
            })
            RegisterThemeObject(sliderTrack, "BackgroundColor3", "SliderBackground")
            Utility.AddCorner(sliderTrack, 4)
            
            local sliderFill = Utility.Create("Frame", {
                Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = theme.SliderFill,
                BorderSizePixel = 0,
                ZIndex = 8,
                Parent = sliderTrack,
            })
            RegisterThemeObject(sliderFill, "BackgroundColor3", "SliderFill")
            Utility.AddCorner(sliderFill, 4)
            
            -- Slider knob
            local sliderKnob = Utility.Create("Frame", {
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new((default - min) / (max - min), 0, 0.5, 0),
                Size = UDim2.new(0, 16, 0, 16),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0,
                ZIndex = 9,
                Parent = sliderTrack,
            })
            Utility.AddCorner(sliderKnob, 8)
            local knobStroke = Utility.AddStroke(sliderKnob, theme.SliderFill, 2, 0)
            RegisterThemeObject(knobStroke, "Color", "SliderFill")
            
            -- Slider input
            local sliderInput = Utility.Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 10),
                Position = UDim2.new(0, 0, 0, -5),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 10,
                Parent = sliderTrack,
            })
            
            local sliding = false
            
            local function updateSlider(inputPos)
                local relativeX = (inputPos - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X
                relativeX = math.clamp(relativeX, 0, 1)
                
                local rawValue = min + (max - min) * relativeX
                currentValue = math.floor(rawValue / increment + 0.5) * increment
                currentValue = math.clamp(currentValue, min, max)
                
                -- Round to avoid floating point
                if increment >= 1 then
                    currentValue = math.floor(currentValue)
                else
                    currentValue = tonumber(string.format("%." .. #tostring(increment):match("%.(%d+)") .. "f", currentValue))
                end
                
                local normalizedValue = (currentValue - min) / (max - min)
                
                Utility.Tween(sliderFill, {Size = UDim2.new(normalizedValue, 0, 1, 0)}, 0.05)
                Utility.Tween(sliderKnob, {Position = UDim2.new(normalizedValue, 0, 0.5, 0)}, 0.05)
                valueLabel.Text = tostring(currentValue) .. suffix
                
                pcall(callback, currentValue)
            end
            
            sliderInput.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = true
                    updateSlider(input.Position.X)
                    Utility.Tween(sliderKnob, {Size = UDim2.new(0, 20, 0, 20)}, 0.1)
                end
            end)
            
            sliderInput.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                    Utility.Tween(sliderKnob, {Size = UDim2.new(0, 16, 0, 16)}, 0.1)
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(input.Position.X)
                end
            end)
            
            -- Hover
            sliderInput.MouseEnter:Connect(function()
                Utility.Tween(sliderFrame, {BackgroundColor3 = Utility.GetTheme().TertiaryBackground}, 0.15)
            end)
            sliderInput.MouseLeave:Connect(function()
                if not sliding then
                    Utility.Tween(sliderFrame, {BackgroundColor3 = Utility.GetTheme().CardBackground}, 0.15)
                end
            end)
            
            local SliderObj = {}
            function SliderObj:Set(value)
                currentValue = math.clamp(value, min, max)
                local normalizedValue = (currentValue - min) / (max - min)
                Utility.Tween(sliderFill, {Size = UDim2.new(normalizedValue, 0, 1, 0)}, 0.2)
                Utility.Tween(sliderKnob, {Position = UDim2.new(normalizedValue, 0, 0.5, 0)}, 0.2)
                valueLabel.Text = tostring(currentValue) .. suffix
                pcall(callback, currentValue)
            end
            function SliderObj:Get()
                return currentValue
            end
            
            if flag then
                Window.Elements[flag] = SliderObj
            end
            
            return SliderObj
        end
        
