            local description = sliderOptions.Description or nil
            local min = sliderOptions.Min or 0
            local max = sliderOptions.Max or 100
            local default = sliderOptions.Default or min
            local increment = sliderOptions.Increment or 1
            local suffix = sliderOptions.Suffix or ""
            local callback = sliderOptions.Callback or function() end
            local icon = sliderOptions.Icon or nil
            local flag = sliderOptions.Flag or nil
            local theme = Utility.GetTheme()
            local parent = getParent(self)
            
            local totalHeight = description and 70 or 56
            local currentValue = default
            
            local sliderFrame = Utility.Create("Frame", {
                Name = "Slider_" .. text,
