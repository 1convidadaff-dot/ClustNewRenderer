                    Position = UDim2.new(0, 14, 0, 8),
                    Size = UDim2.new(0, 22, 0, 22),
                    BackgroundTransparency = 1,
                    Text = icon,
                    TextSize = 16,
                    ZIndex = 7,
                    Parent = sliderFrame,
                })
                leftOffset = 42
            end
            
            local sliderLabel = Utility.Create("TextLabel", {
