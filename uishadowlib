                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 7,
                    Parent = keybindFrame,
                })
                RegisterThemeObject(descLabel, "TextColor3", "DimText")
            end
            
            -- Key display button
            local keyBtn = Utility.Create("TextButton", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -14, 0.5, 0),
                Size = UDim2.new(0, 80, 0, 26),
                BackgroundColor3 = theme.InputBackground,
                Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name,
                TextColor3 = theme.SubText,
                Font = Config.Font,
                TextSize = 12,
                ZIndex = 7,
                Parent = keybindFrame,
            })
            RegisterThemeObject(keyBtn, "BackgroundColor3", "InputBackground")
            RegisterThemeObject(keyBtn, "TextColor3", "SubText")
            Utility.AddCorner(keyBtn, 6)
            local keyStroke = Utility.AddStroke(keyBtn, theme.Border, 1, 0.5)
            
            keyBtn.MouseButton1Click:Connect(function()
                listening = true
                keyBtn.Text = "..."
                Utility.Tween(keyStroke, {Color = Utility.GetTheme().Accent}, 0.2)
            end)
            
            UserInputService.InputBegan:Connect(function(input, processed)
                if listening then
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = input.KeyCode
                        keyBtn.Text = currentKey.Name
                        listening = false
                        Utility.Tween(keyStroke, {Color = Utility.GetTheme().Border}, 0.2)
                        pcall(changedCallback, currentKey)
                    end
                elseif input.KeyCode == currentKey and not processed then
                    pcall(callback)
                end
            end)
            
            local KeybindObj = {}
            function KeybindObj:Set(key)
                currentKey = key
                keyBtn.Text = key.Name
                pcall(changedCallback, key)
            end
            function KeybindObj:Get()
                return currentKey
            end
            
            if flag then Window.Elements[flag] = KeybindObj end
            return KeybindObj
        end
        
