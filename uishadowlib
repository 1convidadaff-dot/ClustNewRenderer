-- GERENCIADOR DE REFERÊNCIAS PARA ATUALIZAÇÃO DE TEMA
-- ═══════════════════════════════════════════════════════════
local ThemeObjects = {}

local function RegisterThemeObject(instance, property, themeKey)
    table.insert(ThemeObjects, {
        Instance = instance,
        Property = property,
        ThemeKey = themeKey,
    })
end

local function UpdateAllThemeObjects()
    local theme = Utility.GetTheme()
    for i = #ThemeObjects, 1, -1 do
        local obj = ThemeObjects[i]
        if obj.Instance and obj.Instance.Parent then
            pcall(function()
                Utility.Tween(obj.Instance, {[obj.Property] = theme[obj.ThemeKey]}, 0.3)
            end)
        else
            table.remove(ThemeObjects, i)
        end
    end
end

