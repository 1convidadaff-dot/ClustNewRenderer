            function Section:AddDropdown(options)
                options = options or {}
                local dropConfig = {
                    Name = options.Name or "Dropdown",
                    Description = options.Description or nil,
                    Items = options.Items or {},
                    Default = options.Default or nil,
                    Multi = options.Multi or false,
                    Flag = options.Flag or nil,
                    Callback = options.Callback or function() end
                }

                local theme = Themes[self._tab._window._library.CurrentTheme]
                self._elementCount = self._elementCount + 1
                local isOpen = false
                local selectedValues = {}

                if dropConfig.Multi then
                    if dropConfig.Default and type(dropConfig.Default) == "table" then
                        for _, v in ipairs(dropConfig.Default) do
                            selectedValues[v] = true
                        end
                    end
                else
                    if dropConfig.Default then
                        selectedValues = dropConfig.Default
                    end
                end

                if dropConfig.Flag then
                    Library.Flags[dropConfig.Flag] = dropConfig.Multi and selectedValues or selectedValues
                end

                local baseHeight = dropConfig.Description and 56 or 42
                local dropdownFrame = Utility.Create("Frame", {
                    Name = "Dropdown_" .. dropConfig.Name,
                    BackgroundColor3 = theme.ElementBackground,
                    Size = UDim2.new(1, 0, 0, baseHeight),
                    ClipsDescendants = true,
                    LayoutOrder = self._elementCount,
                    Parent = self._content
                })
                Utility.AddCorner(dropdownFrame, 6)

                local dropBtn = Utility.Create("TextButton", {
                    Name = "DropButton",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, baseHeight),
                    Text = "",
                    AutoButtonColor = false,
                    Parent = dropdownFrame
                })

                local dropLabel = Utility.Create("TextLabel", {
                    Name = "Label",
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 12, 0, dropConfig.Description and 6 or 0),
                    Size = UDim2.new(0.5, -12, 0, dropConfig.Description and 18 or baseHeight),
                    Font = Enum.Font.GothamSemibold,
                    Text = dropConfig.Name,
                    TextColor3 = theme.TextPrimary,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = dropdownFrame
                })

                if dropConfig.Description then
                    Utility.Create("TextLabel", {
                        Name = "Desc",
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 12, 0, 24),
                        Size = UDim2.new(0.5, -12, 0, 14),
                        Font = Enum.Font.Gotham,
                        Text = dropConfig.Description,
                        TextColor3 = theme.TextDimmed,
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = dropdownFrame
                    })
                end

                local function getDisplayText()
                    if dropConfig.Multi then
                        local selected = {}
                        for k, v in pairs(selectedValues) do
                            if v then table.insert(selected, tostring(k)) end
                        end
                        return #selected > 0 and table.concat(selected, ", ") or "None"
                    else
                        return selectedValues and tostring(selectedValues) or "Select..."
                    end
                end

                local selectedLabel = Utility.Create("TextLabel", {
                    Name = "Selected",
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.5, 0, 0, dropConfig.Description and 6 or 0),
                    Size = UDim2.new(0.5, -36, 0, dropConfig.Description and 18 or baseHeight),
                    Font = Enum.Font.Gotham,
                    Text = getDisplayText(),
                    TextColor3 = theme.Accent,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    Parent = dropdownFrame
                })

                local arrow = Utility.Create("TextLabel", {
                    Name = "Arrow",
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -28, 0, 0),
                    Size = UDim2.new(0, 20, 0, baseHeight),
                    Font = Enum.Font.GothamBold,
                    Text = "▼",
                    TextColor3 = theme.TextDimmed,
                    TextSize = 10,
                    Rotation = 0,
                    Parent = dropdownFrame
                })

                -- Dropdown items container
                local itemContainer = Utility.Create("Frame", {
                    Name = "Items",
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 8, 0, baseHeight + 4),
                    Size = UDim2.new(1, -16, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Parent = dropdownFrame
                })
                Utility.AddListLayout(itemContainer, 2)

                local itemButtons = {}

                local function createItem(itemName)
                    local itemSelected = false
                    if dropConfig.Multi then
                        itemSelected = selectedValues[itemName] or false
                    else
                        itemSelected = selectedValues == itemName
                    end

                    local itemBtn = Utility.Create("TextButton", {
                        Name = "Item_" .. tostring(itemName),
                        BackgroundColor3 = itemSelected and theme.Accent or theme.TertiaryBackground,
                        BackgroundTransparency = itemSelected and 0.8 or 0,
                        Size = UDim2.new(1, 0, 0, 30),
                        Font = Enum.Font.Gotham,
                        Text = "",
                        AutoButtonColor = false,
                        Parent = itemContainer
                    })
                    Utility.AddCorner(itemBtn, 4)

                    local itemLabel = Utility.Create("TextLabel", {
                        Name = "Label",
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 10, 0, 0),
                        Size = UDim2.new(1, -40, 1, 0),
                        Font = Enum.Font.Gotham,
                        Text = tostring(itemName),
                        TextColor3 = itemSelected and theme.Accent or theme.TextSecondary,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = itemBtn
                    })

                    local checkMark = Utility.Create("TextLabel", {
                        Name = "Check",
                        BackgroundTransparency = 1,
                        Position = UDim2.new(1, -28, 0, 0),
                        Size = UDim2.new(0, 20, 1, 0),
                        Font = Enum.Font.GothamBold,
                        Text = itemSelected and "✓" or "",
                        TextColor3 = theme.Accent,
                        TextSize = 14,
                        Parent = itemBtn
                    })

                    itemBtn.MouseEnter:Connect(function()
                        Utility.Tween(itemBtn, {BackgroundColor3 = theme.ElementBackgroundHover}, 0.1)
                    end)
                    itemBtn.MouseLeave:Connect(function()
                        local sel = false
                        if dropConfig.Multi then
                            sel = selectedValues[itemName] or false
                        else
                            sel = selectedValues == itemName
                        end
                        Utility.Tween(itemBtn, {BackgroundColor3 = sel and theme.Accent or theme.TertiaryBackground, BackgroundTransparency = sel and 0.8 or 0}, 0.1)
                    end)

                    itemBtn.MouseButton1Click:Connect(function()
                        if dropConfig.Multi then
                            selectedValues[itemName] = not (selectedValues[itemName] or false)
                            local sel = selectedValues[itemName]
                            checkMark.Text = sel and "✓" or ""
                            Utility.Tween(itemLabel, {TextColor3 = sel and theme.Accent or theme.TextSecondary}, 0.15)
                            Utility.Tween(itemBtn, {BackgroundColor3 = sel and theme.Accent or theme.TertiaryBackground, BackgroundTransparency = sel and 0.8 or 0}, 0.15)
                        else
                            -- Deselect all
                            for _, data in pairs(itemButtons) do
                                data.check.Text = ""
                                Utility.Tween(data.label, {TextColor3 = theme.TextSecondary}, 0.15)
                                Utility.Tween(data.btn, {BackgroundColor3 = theme.TertiaryBackground, BackgroundTransparency = 0}, 0.15)
                            end
                            selectedValues = itemName
                            checkMark.Text = "✓"
                            Utility.Tween(itemLabel, {TextColor3 = theme.Accent}, 0.15)
                            Utility.Tween(itemBtn, {BackgroundColor3 = theme.Accent, BackgroundTransparency = 0.8}, 0.15)
                        end

                        selectedLabel.Text = getDisplayText()
                        if dropConfig.Flag then
                            Library.Flags[dropConfig.Flag] = dropConfig.Multi and selectedValues or selectedValues
                        end
                        pcall(dropConfig.Callback, dropConfig.Multi and selectedValues or selectedValues)
                    end)

                    itemButtons[itemName] = {btn = itemBtn, label = itemLabel, check = checkMark}
                end

                for _, item in ipairs(dropConfig.Items) do
                    createItem(item)
                end

                -- Toggle dropdown
                local function toggleDropdown()
                    isOpen = not isOpen
                    if isOpen then
                        local itemCount = #dropConfig.Items
                        local expandHeight = baseHeight + 8 + math.min(itemCount, 6) * 32
                        Utility.Tween(dropdownFrame, {Size = UDim2.new(1, 0, 0, expandHeight)}, 0.25, Enum.EasingStyle.Back)
                        Utility.Tween(arrow, {Rotation = 180}, 0.25)
                    else
                        Utility.Tween(dropdownFrame, {Size = UDim2.new(1, 0, 0, baseHeight)}, 0.2)
                        Utility.Tween(arrow, {Rotation = 0}, 0.2)
                    end
                end

                dropBtn.MouseButton1Click:Connect(toggleDropdown)

                dropBtn.MouseEnter:Connect(function()
                    Utility.Tween(dropdownFrame, {BackgroundColor3 = theme.ElementBackgroundHover}, 0.15)
                end)
                dropBtn.MouseLeave:Connect(function()
                    Utility.Tween(dropdownFrame, {BackgroundColor3 = theme.ElementBackground}, 0.15)
                end)

                local DropdownObj = {}
                function DropdownObj:Set(value)
                    if dropConfig.Multi and type(value) == "table" then
                        selectedValues = value
                    else
                        selectedValues = value
                    end
                    selectedLabel.Text = getDisplayText()
                    if dropConfig.Flag then
                        Library.Flags[dropConfig.Flag] = selectedValues
                    end
                    pcall(dropConfig.Callback, selectedValues)
                end
                function DropdownObj:Get()
                    return selectedValues
                end
                function DropdownObj:Refresh(newItems, keepSelected)
                    -- Clear existing
                    for _, data in pairs(itemButtons) do
                        data.btn:Destroy()
                    end
                    itemButtons = {}
                    dropConfig.Items = newItems
                    if not keepSelected then
                        if dropConfig.Multi then
                            selectedValues = {}
                        else
                            selectedValues = nil
                        end
                    end
                    for _, item in ipairs(newItems) do
                        createItem(item)
                    end
                    selectedLabel.Text = getDisplayText()
                end
                function DropdownObj:Add(item)
                    table.insert(dropConfig.Items, item)
                    createItem(item)
                end
                function DropdownObj:Remove(item)
                    for i, v in ipairs(dropConfig.Items) do
                        if v == item then
                            table.remove(dropConfig.Items, i)
                            break
                        end
                    end
                    if itemButtons[item] then
                        itemButtons[item].btn:Destroy()
                        itemButtons[item] = nil
                    end
                    if dropConfig.Multi then
                        selectedValues[item] = nil
                    elseif selectedValues == item then
                        selectedValues = nil
                    end
                    selectedLabel.Text = getDisplayText()
                end
                return DropdownObj
            end

