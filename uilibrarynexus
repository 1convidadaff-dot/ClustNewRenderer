                    Size = UDim2.new(1, -24, 0, 6),
                    Parent = sliderFrame
                })
                Utility.AddCorner(sliderTrack, 3)

                local sliderFill = Utility.Create("Frame", {
                    Name = "Fill",
                    BackgroundColor3 = theme.SliderFill,
                    Size = UDim2.new((currentValue - sliderConfig.Min) / (sliderConfig.Max - sliderConfig.Min), 0, 1, 0),
                    Parent = sliderTrack
                })
                Utility.AddCorner(sliderFill, 3)

                -- Slider Knob
                local knob = Utility.Create("Frame", {
                    Name = "Knob",
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    Position = UDim2.new((currentValue - sliderConfig.Min) / (sliderConfig.Max - sliderConfig.Min), 0, 0.5, 0),
                    Size = UDim2.new(0, 14, 0, 14),
                    ZIndex = 2,
                    Parent = sliderTrack
                })
                Utility.AddCorner(knob, 7)
                Utility.AddStroke(knob, theme.SliderFill, 2, 0)

                local knobShadow = Utility.Create("ImageLabel", {
                    Name = "Shadow",
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.5, 0, 0.5, 1),
                    Size = UDim2.new(1, 8, 1, 8),
                    Image = "rbxassetid://5028857084",
                    ImageColor3 = Color3.fromRGB(0, 0, 0),
                    ImageTransparency = 0.6,
                    ZIndex = 1,
                    Parent = knob
                })

                local sliding = false

                local function updateSlider(input)
                    local relativeX = math.clamp(
                        (input.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X,
                        0, 1
                    )
                    local rawValue = sliderConfig.Min + (sliderConfig.Max - sliderConfig.Min) * relativeX
                    local value = math.floor(rawValue / sliderConfig.Increment + 0.5) * sliderConfig.Increment
                    value = math.clamp(value, sliderConfig.Min, sliderConfig.Max)

                    -- Round to avoid floating point errors
                    if sliderConfig.Increment >= 1 then
                        value = math.floor(value)
                    end

                    currentValue = value
                    if sliderConfig.Flag then
                        Library.Flags[sliderConfig.Flag] = value
                    end

                    local normalizedValue = (value - sliderConfig.Min) / (sliderConfig.Max - sliderConfig.Min)
                    Utility.Tween(sliderFill, {Size = UDim2.new(normalizedValue, 0, 1, 0)}, 0.05)
                    Utility.Tween(knob, {Position = UDim2.new(normalizedValue, 0, 0.5, 0)}, 0.05)
                    valueLabel.Text = tostring(value) .. sliderConfig.Suffix

                    pcall(sliderConfig.Callback, value)
                end

                sliderTrack.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = true
                        Utility.Tween(knob, {Size = UDim2.new(0, 18, 0, 18)}, 0.15, Enum.EasingStyle.Back)
                        updateSlider(input)
                    end
                end)

                knob.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = true
                        Utility.Tween(knob, {Size = UDim2.new(0, 18, 0, 18)}, 0.15, Enum.EasingStyle.Back)
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        updateSlider(input)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        sliding = false
                        Utility.Tween(knob, {Size = UDim2.new(0, 14, 0, 14)}, 0.15)
                    end
                end)

                sliderFrame.MouseEnter:Connect(function()
                    Utility.Tween(sliderFrame, {BackgroundColor3 = theme.ElementBackgroundHover}, 0.15)
                end)
                sliderFrame.MouseLeave:Connect(function()
                    Utility.Tween(sliderFrame, {BackgroundColor3 = theme.ElementBackground}, 0.15)
                end)

                local SliderObj = {}
                function SliderObj:Set(value)
                    value = math.clamp(value, sliderConfig.Min, sliderConfig.Max)
                    currentValue = value
                    if sliderConfig.Flag then
                        Library.Flags[sliderConfig.Flag] = value
                    end
                    local norm = (value - sliderConfig.Min) / (sliderConfig.Max - sliderConfig.Min)
                    Utility.Tween(sliderFill, {Size = UDim2.new(norm, 0, 1, 0)}, 0.2)
                    Utility.Tween(knob, {Position = UDim2.new(norm, 0, 0.5, 0)}, 0.2)
                    valueLabel.Text = tostring(value) .. sliderConfig.Suffix
                    pcall(sliderConfig.Callback, value)
                end
                function SliderObj:Get()
                    return currentValue
                end
                return SliderObj
            end

