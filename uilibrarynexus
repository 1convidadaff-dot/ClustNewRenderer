function Library:Notify(options)
    options = options or {}
    local title = options.Title or "Notification"
    local message = options.Message or ""
    local duration = options.Duration or 4
    local notifType = options.Type or "Info" -- Info, Success, Warning, Error

    local theme = Themes[self.CurrentTheme]

    local typeColors = {
        Info = theme.Accent,
        Success = theme.Success,
        Warning = theme.Warning,
        Error = theme.Error
    }

    local typeIcons = {
        Info = "ℹ️",
        Success = "✅",
        Warning = "⚠️",
        Error = "❌"
    }

    if not self._notificationHolder then
        self._notificationHolder = Utility.Create("Frame", {
            Name = "NexusUI_Notifications",
            AnchorPoint = Vector2.new(1, 1),
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -20, 1, -20),
            Size = UDim2.new(0, 320, 1, -40),
            Parent = self._screenGui
        })
        Utility.AddListLayout(self._notificationHolder, 8, Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Bottom)
    end

    local notifFrame = Utility.Create("Frame", {
        Name = "Notification",
        BackgroundColor3 = theme.Notification,
        Size = UDim2.new(1, 0, 0, 0),
        ClipsDescendants = true,
        Parent = self._notificationHolder
    })
    Utility.AddCorner(notifFrame, 8)
    Utility.AddStroke(notifFrame, theme.Border, 1, 0.5)

    local accentBar = Utility.Create("Frame", {
        Name = "AccentBar",
        BackgroundColor3 = typeColors[notifType] or theme.Accent,
        Size = UDim2.new(0, 3, 1, -8),
        Position = UDim2.new(0, 4, 0, 4),
        Parent = notifFrame
    })
    Utility.AddCorner(accentBar, 2)

    local contentHolder = Utility.Create("Frame", {
        Name = "Content",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 0),
        Size = UDim2.new(1, -24, 1, 0),
        Parent = notifFrame
    })
    Utility.AddPadding(contentHolder, 10, 10, 0, 0)

    local titleLabel = Utility.Create("TextLabel", {
        Name = "Title",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -30, 0, 18),
        Font = Enum.Font.GothamBold,
        Text = title,
        TextColor3 = theme.TextPrimary,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = contentHolder
    })

    local messageLabel = Utility.Create("TextLabel", {
        Name = "Message",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 22),
        Size = UDim2.new(1, 0, 0, 0),
        Font = Enum.Font.Gotham,
        Text = message,
        TextColor3 = theme.TextSecondary,
        TextSize = 12,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = contentHolder
    })

    local closeBtn = Utility.Create("TextButton", {
        Name = "Close",
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -20, 0, 8),
        Size = UDim2.new(0, 20, 0, 20),
        Font = Enum.Font.GothamBold,
        Text = "×",
        TextColor3 = theme.TextDimmed,
        TextSize = 18,
        Parent = notifFrame
    })

    local progressBar = Utility.Create("Frame", {
        Name = "Progress",
        BackgroundColor3 = typeColors[notifType] or theme.Accent,
        BackgroundTransparency = 0.5,
        Position = UDim2.new(0, 0, 1, -2),
        Size = UDim2.new(1, 0, 0, 2),
        Parent = notifFrame
    })
    Utility.AddCorner(progressBar, 1)

    -- Calculate height
    task.wait()
    local textHeight = messageLabel.TextBounds.Y
    local totalHeight = 22 + textHeight + 24

    -- Animate in
    Utility.Tween(notifFrame, {Size = UDim2.new(1, 0, 0, totalHeight)}, 0.35, Enum.EasingStyle.Back)

    -- Progress bar animation
    Utility.Tween(progressBar, {Size = UDim2.new(0, 0, 0, 2)}, duration)

    -- Close function
    local function closeNotification()
        Utility.Tween(notifFrame, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.3)
        task.delay(0.3, function()
            notifFrame:Destroy()
        end)
    end

    closeBtn.MouseButton1Click:Connect(closeNotification)
    task.delay(duration, closeNotification)

    closeBtn.MouseEnter:Connect(function()
        Utility.Tween(closeBtn, {TextColor3 = theme.TextPrimary}, 0.15)
    end)
    closeBtn.MouseLeave:Connect(function()
        Utility.Tween(closeBtn, {TextColor3 = theme.TextDimmed}, 0.15)
    end)
end

