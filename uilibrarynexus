                })

                local function updateColor()
                    currentColor = Color3.fromHSV(h, s, v)
                    colorPreview.BackgroundColor3 = currentColor
                    svPicker.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                    hueCursor.Position = UDim2.new(0.5, 0, h, 0)
                    rgbLabel.Text = string.format("R: %d  G: %d  B: %d", currentColor.R * 255, currentColor.G * 255, currentColor.B * 255)

                    if colorConfig.Flag then
                        Library.Flags[colorConfig.Flag] = currentColor
                    end
                    pcall(colorConfig.Callback, currentColor)
                end

                -- SV Picker interaction
                local svDragging = false
                svPicker.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        svDragging = true
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if svDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        s = math.clamp((input.Position.X - svPicker.AbsolutePosition.X) / svPicker.AbsoluteSize.X, 0, 1)
                        v = 1 - math.clamp((input.Position.Y - svPicker.AbsolutePosition.Y) / svPicker.AbsoluteSize.Y, 0, 1)
                        updateColor()
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        svDragging = false
                    end
                end)

                -- Hue interaction
                local hueDragging = false
                hueSlider.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        hueDragging = true
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if hueDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        h = math.clamp((input.Position.Y - hueSlider.AbsolutePosition.Y) / hueSlider.AbsoluteSize.Y, 0, 1)
                        updateColor()
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        hueDragging = false
                    end
                end)

                -- Toggle color picker
                colorBtn.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    Utility.Tween(colorFrame, {
                        Size = UDim2.new(1, 0, 0, isOpen and 174 or 38)
                    }, 0.25, Enum.EasingStyle.Back)
                end)

                colorBtn.MouseEnter:Connect(function()
                    Utility.Tween(colorFrame, {BackgroundColor3 = theme.ElementBackgroundHover}, 0.15)
                end)
                colorBtn.MouseLeave:Connect(function()
                    Utility.Tween(colorFrame, {BackgroundColor3 = theme.ElementBackground}, 0.15)
                end)

                local ColorObj = {}
                function ColorObj:Set(color)
                    h, s, v = color:ToHSV()
                    updateColor()
                end
                function ColorObj:Get()
                    return currentColor
                end
                return ColorObj
            end

            -- ═══════════════════════════
            -- KEYBIND
            -- ═══════════════════════════
            function Section:AddKeybind(options)
                options = options or {}
                local keybindConfig = {
                    Name = options.Name or "Keybind",
                    Description = options.Description or nil,
                    Default = options.Default or Enum.KeyCode.Unknown,
                    Flag = options.Flag or nil,
                    Callback = options.Callback or function() end,
                    ChangedCallback = options.ChangedCallback or function() end
                }

                local theme = Themes[self._tab._window._library.CurrentTheme]
                self._elementCount = self._elementCount + 1
                local currentKey = keybindConfig.Default
                local isListening = false

                if keybindConfig.Flag then
                    Library.Flags[keybindConfig.Flag] = currentKey
                end

                local keybindFrame = Utility.Create("Frame", {
                    Name = "Keybind_" .. keybindConfig.Name,
                    BackgroundColor3 = theme.ElementBackground,
                    Size = UDim2.new(1, 0, 0, keybindConfig.Description and 52 or 38),
                    LayoutOrder = self._elementCount,
                    Parent = self._content
                })
                Utility.AddCorner(keybindFrame, 6)

                local keybindLabel = Utility.Create("TextLabel", {
                    Name = "Label",
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 12, 0, keybindConfig.Description and 6 or 0),
                    Size = UDim2.new(1, -120, 0, keybindConfig.Description and 20 or 38),
                    Font = Enum.Font.GothamSemibold,
                    Text = keybindConfig.Name,
                    TextColor3 = theme.TextPrimary,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = keybindFrame
                })

                if keybindConfig.Description then
                    Utility.Create("TextLabel", {
                        Name = "Desc",
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 12, 0, 26),
                        Size = UDim2.new(1, -120, 0, 18),
                        Font = Enum.Font.Gotham,
                        Text = keybindConfig.Description,
                        TextColor3 = theme.TextDimmed,
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = keybindFrame
                    })
                end

                local keyBtnFrame = Utility.Create("Frame", {
                    Name = "KeyFrame",
                    AnchorPoint = Vector2.new(1, 0.5),
                    BackgroundColor3 = theme.TertiaryBackground,
                    Position = UDim2.new(1, -12, 0.5, 0),
                    Size = UDim2.new(0, 80, 0, 24),
                    Parent = keybindFrame
                })
                Utility.AddCorner(keyBtnFrame, 4)
                Utility.AddStroke(keyBtnFrame, theme.Border, 1, 0.5)

                local keyBtn = Utility.Create("TextButton", {
                    Name = "KeyButton",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Font = Enum.Font.GothamSemibold,
                    Text = currentKey ~= Enum.KeyCode.Unknown and currentKey.Name or "None",
                    TextColor3 = theme.TextSecondary,
                    TextSize = 11,
                    AutoButtonColor = false,
                    Parent = keyBtnFrame
                })

                keyBtn.MouseButton1Click:Connect(function()
                    isListening = true
                    keyBtn.Text = "..."
                    Utility.Tween(keyBtnFrame, {BackgroundColor3 = theme.Accent}, 0.2)
                    Utility.Tween(keyBtn, {TextColor3 = Color3.fromRGB(255, 255, 255)}, 0.2)
                end)

                UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if isListening then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode == Enum.KeyCode.Escape then
                                currentKey = Enum.KeyCode.Unknown
                                keyBtn.Text = "None"
                            else
                                currentKey = input.KeyCode
                                keyBtn.Text = input.KeyCode.Name
                            end
                            isListening = false
                            Utility.Tween(keyBtnFrame, {BackgroundColor3 = theme.TertiaryBackground}, 0.2)
                            Utility.Tween(keyBtn, {TextColor3 = theme.TextSecondary}, 0.2)
                            if keybindConfig.Flag then
                                Library.Flags[keybindConfig.Flag] = currentKey
                            end
                            pcall(keybindConfig.ChangedCallback, currentKey)
                        end
                    elseif not gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode == currentKey then
                            pcall(keybindConfig.Callback, currentKey)
                        end
                    end
                end)

                keybindFrame.MouseEnter:Connect(function()
                    Utility.Tween(keybindFrame, {BackgroundColor3 = theme.ElementBackgroundHover}, 0.15)
                end)
                keybindFrame.MouseLeave:Connect(function()
                    Utility.Tween(keybindFrame, {BackgroundColor3 = theme.ElementBackground}, 0.15)
                end)

                local KeybindObj = {}
                function KeybindObj:Set(key)
                    currentKey = key
                    keyBtn.Text = key ~= Enum.KeyCode.Unknown and key.Name or "None"
                    if keybindConfig.Flag then
                        Library.Flags[keybindConfig.Flag] = key
                    end
                end
                function KeybindObj:Get()
                    return currentKey
                end
                return KeybindObj
            end

            -- ═══════════════════════════
            -- LABEL / DESCRIPTION
            -- ═══════════════════════════
            function Section:AddLabel(options)
                options = options or {}
                local labelConfig = {
                    Text = options.Text or "Label",
                    Description = options.Description or nil,
                    Color = options.Color or nil
                }

                local theme = Themes[self._tab._window._library.CurrentTheme]
                self._elementCount = self._elementCount + 1

                local labelFrame = Utility.Create("Frame", {
                    Name = "Label",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, labelConfig.Description and 36 or 22),
                    LayoutOrder = self._elementCount,
                    Parent = self._content
                })

                local labelText = Utility.Create("TextLabel", {
                    Name = "Text",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 18),
                    Font = Enum.Font.GothamSemibold,
                    Text = labelConfig.Text,
                    TextColor3 = labelConfig.Color or theme.TextPrimary,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = labelFrame
                })

                if labelConfig.Description then
                    Utility.Create("TextLabel", {
                        Name = "Desc",
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 18),
                        Size = UDim2.new(1, 0, 0, 16),
                        Font = Enum.Font.Gotham,
                        Text = labelConfig.Description,
                        TextColor3 = theme.TextDimmed,
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = labelFrame
                    })
                end

                local LabelObj = {}
                function LabelObj:Set(text)
                    labelText.Text = text
                end
                return LabelObj
            end

            -- ═══════════════════════════
            -- PARAGRAPH / TEXT BLOCK
            -- ═══════════════════════════
            function Section:AddParagraph(options)
                options = options or {}
                local paraConfig = {
                    Title = options.Title or "Paragraph",
                    Content = options.Content or ""
                }

                local theme = Themes[self._tab._window._library.CurrentTheme]
                self._elementCount = self._elementCount + 1

                local paraFrame = Utility.Create("Frame", {
                    Name = "Paragraph",
                    BackgroundColor3 = theme.TertiaryBackground,
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    LayoutOrder = self._elementCount,
                    Parent = self._content
                })
                Utility.AddCorner(paraFrame, 6)
                Utility.AddPadding(paraFrame, 10, 10, 12, 12)

                local accentLine = Utility.Create("Frame", {
                    Name = "Accent",
                    BackgroundColor3 = theme.Accent,
                    Position = UDim2.new(0, -8, 0, -6),
                    Size = UDim2.new(0, 3, 1, 12),
                    Parent = paraFrame
                })
                Utility.AddCorner(accentLine, 2)

                local titleLabel = Utility.Create("TextLabel", {
                    Name = "Title",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 18),
                    Font = Enum.Font.GothamBold,
                    Text = paraConfig.Title,
                    TextColor3 = theme.TextPrimary,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    LayoutOrder = 1,
                    Parent = paraFrame
                })

                local contentLabel = Utility.Create("TextLabel", {
                    Name = "Content",
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 22),
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Font = Enum.Font.Gotham,
                    Text = paraConfig.Content,
                    TextColor3 = theme.TextSecondary,
                    TextSize = 12,
                    TextWrapped = true,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    LayoutOrder = 2,
                    Parent = paraFrame
                })

                local ParaObj = {}
                function ParaObj:Set(title, content)
                    if title then titleLabel.Text = title end
                    if content then contentLabel.Text = content end
                end
                return ParaObj
            end

            -- ═══════════════════════════
            -- DIVIDER / SEPARATOR
            -- ═══════════════════════════
            function Section:AddDivider()
                local theme = Themes[self._tab._window._library.CurrentTheme]
                self._elementCount = self._elementCount + 1

                Utility.Create("Frame", {
                    Name = "Divider",
                    BackgroundColor3 = theme.Divider,
                    Size = UDim2.new(1, 0, 0, 1),
                    LayoutOrder = self._elementCount,
                    Parent = self._content
                })
            end

            return Section
        end

        -- ═══════════════════════════════
        -- ADD ELEMENTS DIRECTLY TO TAB
        -- (without explicit section)
        -- ═══════════════════════════════
        local defaultSection = Tab:CreateSection({Name = ""})

        function Tab:AddButton(options)
            return defaultSection:AddButton(options)
        end
        function Tab:AddToggle(options)
            return defaultSection:AddToggle(options)
        end
        function Tab:AddSlider(options)
            return defaultSection:AddSlider(options)
        end
        function Tab:AddTextbox(options)
            return defaultSection:AddTextbox(options)
        end
        function Tab:AddDropdown(options)
            return defaultSection:AddDropdown(options)
        end
        function Tab:AddColorPicker(options)
            return defaultSection:AddColorPicker(options)
        end
        function Tab:AddKeybind(options)
            return defaultSection:AddKeybind(options)
        end
        function Tab:AddLabel(options)
            return defaultSection:AddLabel(options)
        end
        function Tab:AddParagraph(options)
            return defaultSection:AddParagraph(options)
        end
        function Tab:AddDivider()
            return defaultSection:AddDivider()
        end

        -- Search functionality
        searchBox:GetPropertyChangedSignal("Text"):Connect(function()
            local searchText = searchBox.Text:lower()
            for _, tab in ipairs(self.Tabs) do
                local tabName = tab.Name:lower()
                if searchText == "" or tabName:find(searchText) then
                    tab._button.Visible = true
                else
                    tab._button.Visible = false
                end
            end
        end)

        return Tab
    end

    -- ═══════════════════════════════════
    -- SET THEME METHOD
    -- ═══════════════════════════════════
    function Window:SetTheme(themeName)
        if Themes[themeName] then
            self._library.CurrentTheme = themeName
            self._library:Notify({
                Title = "Theme Changed",
                Message = "Theme set to " .. themeName,
                Type = "Success",
                Duration = 2
            })
        end
    end

    -- ═══════════════════════════════════
    -- SET TITLE/SUBTITLE
    -- ═══════════════════════════════════
    function Window:SetTitle(title)
        titleLabel.Text = title
    end
    function Window:SetSubtitle(subtitle)
        subtitleLabel.Text = subtitle
    end

    -- ═══════════════════════════════════
    -- TOGGLE KEY CHANGE
    -- ═══════════════════════════════════
    function Window:SetToggleKey(key)
        self._library.ToggleKey = key
    end

    -- ═══════════════════════════════════
    -- DESTROY
    -- ═══════════════════════════════════
    function Window:Destroy()
        screenGui:Destroy()
    end

    -- ═══════════════════════════════════
    -- CONFIGURATION TAB (Built-in)
    -- ═══════════════════════════════════
    local configTab = Window:CreateTab({
        Name = "Configuration",
        Icon = "⚙️",
        LayoutOrder = 999
    })

    local uiSection = configTab:CreateSection({
        Name = "UI Settings",
        Description = "Customize the UI Library behavior"
    })

    -- Theme selector
    local themeNames = {}
    for name, _ in pairs(Themes) do
        table.insert(themeNames, name)
    end
    table.sort(themeNames)

    uiSection:AddDropdown({
        Name = "Theme",
        Description = "Change the UI color theme",
        Items = themeNames,
        Default = self.CurrentTheme,
        Callback = function(value)
            Window:SetTheme(value)
        end
    })

    -- Toggle key config
    uiSection:AddKeybind({
        Name = "Toggle UI Key",
        Description = "Key to show/hide the UI",
        Default = self.ToggleKey,
        ChangedCallback = function(key)
            Window:SetToggleKey(key)
        end
    })

    -- UI Info
    local infoSection = configTab:CreateSection({
        Name = "Information",
        Description = "About NexusUI"
    })

    infoSection:AddParagraph({
        Title = "NexusUI v2.0",
        Content = "A professional and modern UI Library for Roblox.\n\nFeatures:\n• Multiple themes (Dark, Light, Midnight, Ocean, Rose)\n• Draggable window\n• Toggle with external button or keybind\n• Full element suite: buttons, toggles, sliders, dropdowns, color pickers, keybinds, textboxes\n• Sections, labels, paragraphs, dividers\n• Notification system\n• Flag system for easy value access\n• Search tabs"
    })

    infoSection:AddLabel({
        Text = "Made with ❤️ by NexusUI Team",
        Color = theme.Accent
    })

    -- Opening animation
    mainFrame.Size = UDim2.new(0, 0, 0, 0)
    mainFrame.BackgroundTransparency = 1
    task.delay(0.1, function()
        Utility.Tween(mainFrame, {
            Size = windowConfig.Size,
            BackgroundTransparency = 0
        }, 0.5, Enum.EasingStyle.Back)
    end)

    -- Notify on load
    task.delay(1, function()
        self:Notify({
            Title = "NexusUI Loaded",
            Message = windowConfig.Title .. " has been loaded successfully! Press " .. self.ToggleKey.Name .. " to toggle.",
            Type = "Success",
            Duration = 5
        })
    end)

    return Window
end

-- ═══════════════════════════════════════
-- RETURN LIBRARY
-- ═══════════════════════════════════════
return Library
