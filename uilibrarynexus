        -- Tab Selection
        local function selectTab()
            -- Deselect all tabs
            for _, tab in ipairs(self.Tabs) do
                Utility.Tween(tab._button, {BackgroundColor3 = theme.TabInactive, BackgroundTransparency = 0.5}, 0.2)
                Utility.Tween(tab._indicator, {BackgroundTransparency = 1}, 0.2)
                Utility.Tween(tab._nameLabel, {TextColor3 = theme.TextSecondary}, 0.2)
                Utility.Tween(tab._iconLabel, {TextColor3 = theme.TextDimmed}, 0.2)
                tab._page.Visible = false
            end

            -- Select this tab
            Utility.Tween(tabButton, {BackgroundColor3 = theme.TabActive, BackgroundTransparency = 0.85}, 0.2)
            Utility.Tween(tabIndicator, {BackgroundTransparency = 0}, 0.2)
            Utility.Tween(tabName, {TextColor3 = theme.TextPrimary}, 0.2)
            Utility.Tween(tabIcon, {TextColor3 = theme.Accent}, 0.2)
            tabPage.Visible = true
            self.ActiveTab = Tab
        end

        tabButton.MouseButton1Click:Connect(selectTab)

        -- Hover effects
        tabButton.MouseEnter:Connect(function()
            if self.ActiveTab ~= Tab then
                Utility.Tween(tabButton, {BackgroundTransparency = 0.3}, 0.15)
                Utility.Tween(tabName, {TextColor3 = theme.TextPrimary}, 0.15)
            end
        end)
        tabButton.MouseLeave:Connect(function()
            if self.ActiveTab ~= Tab then
                Utility.Tween(tabButton, {BackgroundTransparency = 0.5}, 0.15)
                Utility.Tween(tabName, {TextColor3 = theme.TextSecondary}, 0.15)
            end
        end)

        -- Auto-select first tab
        if #self.Tabs == 1 then
            selectTab()
        end

